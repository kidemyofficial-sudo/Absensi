generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GURU
  ORANG_TUA
  OWNER
}

enum AttendanceStatus {
  HADIR
  IZIN
  SAKIT
  ALPA
}

enum StudentStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                 String    @id @default(cuid())
  name               String
  phone              String    @unique
  password           String
  role               Role
  status             UserStatus @default(PENDING)
  failedLoginAttempts Int      @default(0)
  lockedUntil        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  students       Student[]          @relation("ParentStudents")
  attendances    Attendance[]       @relation("TeacherAttendances")
  lessons        Lesson[]
  notifications  Notification[]
  branchTeachers BranchTeacher[]
  tasks          MyTask[]
  schedules      TeacherSchedule[]
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

model Student {
  id            String        @id @default(cuid())
  name          String
  kodeSiswa     String        @unique // Kode acak, contoh: STD-7X9K2
  ttl           String        @db.VarChar(255)
  domisili      String        @db.VarChar(500)
  asalSekolah   String        @db.VarChar(255)
  cabangDaerah  String?
  parentId      String
  biayaPerSiswa Int           @default(50000)
  status        StudentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  parent          User          @relation("ParentStudents", fields: [parentId], references: [id])
  attendances     Attendance[]
  branchTeachers  BranchTeacher[]
  lessons         Lesson[]

  @@index([status])
  @@index([cabangDaerah])
  @@index([parentId])
  @@index([createdAt])
}

model Attendance {
  id          String           @id @default(cuid())
  studentId   String
  teacherId   String
  date        DateTime         @db.Date
  status      AttendanceStatus
  note        String?
  createdAt   DateTime         @default(now())

  // Relations
  student Student @relation(fields: [studentId], references: [id])
  teacher User    @relation("TeacherAttendances", fields: [teacherId], references: [id])

  @@unique([studentId, date])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])
}

model BranchTeacher {
  id             String  @id @default(cuid())
  userId         String
  cabangDaerah   String
  provinsi       String
  kotaKabupaten  String
  mataPelajaran  String
  biayaPerSesi   Int     @default(50000)
  persentaseOwner Int    @default(40)
  persentaseGuru  Int    @default(60)
  nominalOwner    Int?   @default(20000)
  nominalGuru     Int?   @default(30000)

  // Relations
  user    User      @relation(fields: [userId], references: [id])
  student Student[]

  @@unique([userId, cabangDaerah])
  @@index([cabangDaerah])
  @@index([userId])
}

model Lesson {
  id                String   @id @default(cuid())
  tanggalLes        DateTime @db.Date
  guruId            String
  studentId         String?
  biayaPerSiswa     Int      // Biaya per siswa untuk les ini (bervariasi per murid)
  namaGuru          String
  whatsappGuru      String
  jenisPembelajaran String
  lokasiMengajar    String
  kelasMurid        String?
  jumlahMurid       Int
  namaMurid         String
  catatanMateri     String
  kritikSaran       String?
  fotoUrl           String?
  jamMulai          String
  jamSelesai        String
  namaWaliMurid     String
  whatsappWaliMurid String?
  createdAt         DateTime @default(now())

  // Relations
  guru     User            @relation(fields: [guruId], references: [id])
  student  Student?        @relation(fields: [studentId], references: [id])
  revenue  LessonRevenue?
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // CREATE, UPDATE, DELETE
  entity    String   // Student, Lesson, User, BranchTeacher
  entityId  String
  oldData   Json?
  newData   Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model LessonRevenue {
  id                  String   @id @default(cuid())
  lessonId            String   @unique
  biayaPerSesi        Int
  jumlahMurid         Int
  biayaTotal          Int
  persentaseOwner     Int
  persentaseGuru      Int
  nominalOwnerPerSesi Int?
  nominalGuruPerSesi  Int?
  pendapatanOwner     Int
  pendapatanGuru      Int
  createdAt           DateTime @default(now())

  // Relations
  lesson Lesson @relation(fields: [lessonId], references: [id])
}

model MyTask {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @db.Date
  title       String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relasi
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model TeacherSchedule {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @db.Date
  time        String   // Jam mulai: "09:30" (format 24h) atau "09:30 AM"
  timeEnd     String?  // Jam selesai: "11:00" (format 24h) - opsional
  title       String
  description String?  // Contoh lokasi: "Joyo Hotel, Kaliurang"
  notified    Boolean  @default(false)
  category    String   @default("JADWAL") // "JADWAL" atau "ACARA"
  recurrence  String   @default("ONCE")   // "ONCE" atau "WEEKLY"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relasi
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}
