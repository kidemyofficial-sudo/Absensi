generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GURU
  ORANG_TUA
  OWNER
}

enum AttendanceStatus {
  HADIR
  IZIN
  SAKIT
  ALPA
}

enum StudentStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                 String    @id @default(cuid())
  name               String
  phone              String    @unique
  password           String
  role               Role
  failedLoginAttempts Int      @default(0)
  lockedUntil        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  students       Student[]          @relation("ParentStudents")
  attendances    Attendance[]       @relation("TeacherAttendances")
  lessons        Lesson[]
  notifications  Notification[]
  branchTeachers BranchTeacher[]
}

model Student {
  id            String        @id @default(cuid())
  name          String
  kodeSiswa     String        @unique // Kode acak, contoh: STD-7X9K2
  ttl           String        @db.VarChar(255)
  domisili      String        @db.VarChar(500)
  asalSekolah   String        @db.VarChar(255)
  cabangDaerah  String?
  parentId      String
  biayaPerSiswa Int           @default(50000)
  status        StudentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  parent          User          @relation("ParentStudents", fields: [parentId], references: [id])
  attendances     Attendance[]
  branchTeachers  BranchTeacher[]
  lessons         Lesson[]

  @@index([status])
  @@index([cabangDaerah])
  @@index([parentId])
  @@index([createdAt])
}

model Attendance {
  id          String           @id @default(cuid())
  studentId   String
  teacherId   String
  date        DateTime         @db.Date
  status      AttendanceStatus
  note        String?
  createdAt   DateTime         @default(now())

  // Relations
  student Student @relation(fields: [studentId], references: [id])
  teacher User    @relation("TeacherAttendances", fields: [teacherId], references: [id])

  @@unique([studentId, date])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])
}

model BranchTeacher {
  id             String  @id @default(cuid())
  userId         String
  cabangDaerah   String
  provinsi       String
  kotaKabupaten  String
  mataPelajaran  String
  biayaPerSesi   Int     @default(50000)
  persentaseOwner Int    @default(40)
  persentaseGuru  Int    @default(60)

  // Relations
  user    User      @relation(fields: [userId], references: [id])
  student Student[]

  @@unique([userId, cabangDaerah])
  @@index([cabangDaerah])
  @@index([userId])
}

model Lesson {
  id                String   @id @default(cuid())
  tanggalLes        DateTime @db.Date
  guruId            String
  studentId         String?
  biayaPerSiswa     Int      // Biaya per siswa untuk les ini (bervariasi per murid)
  namaGuru          String
  whatsappGuru      String
  jenisPembelajaran String
  lokasiMengajar    String
  kelasMurid        String?
  jumlahMurid       Int
  namaMurid         String
  catatanMateri     String
  kritikSaran       String?
  fotoUrl           String?
  jamMulai          String
  jamSelesai        String
  namaWaliMurid     String
  whatsappWaliMurid String?
  createdAt         DateTime @default(now())

  // Relations
  guru     User            @relation(fields: [guruId], references: [id])
  student  Student?        @relation(fields: [studentId], references: [id])
  revenue  LessonRevenue?
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // CREATE, UPDATE, DELETE
  entity    String   // Student, Lesson, User, BranchTeacher
  entityId  String
  oldData   Json?
  newData   Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model LessonRevenue {
  id              String   @id @default(cuid())
  lessonId        String   @unique
  biayaPerSesi    Int
  jumlahMurid     Int
  biayaTotal      Int
  persentaseOwner Int
  persentaseGuru  Int
  pendapatanOwner Int
  pendapatanGuru  Int
  createdAt       DateTime @default(now())

  // Relations
  lesson Lesson @relation(fields: [lessonId], references: [id])
}
