generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GURU
  ORANG_TUA
  OWNER
}

enum AttendanceStatus {
  HADIR
  IZIN
  SAKIT
  ALPA
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  students          Student[]          @relation("ParentStudents")
  attendances       Attendance[]       @relation("TeacherAttendances")
  notifications     Notification[]
  classroomTeachers ClassroomTeacher[]
}

model Student {
  id        String   @id @default(cuid())
  name      String
  nis       String   @unique
  class     String
  parentId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  parent              User               @relation("ParentStudents", fields: [parentId], references: [id])
  attendances         Attendance[]
  classroomTeachers   ClassroomTeacher[]
}

model Attendance {
  id          String           @id @default(cuid())
  studentId   String
  teacherId   String
  date        DateTime         @db.Date
  status      AttendanceStatus
  note        String?
  createdAt   DateTime         @default(now())

  // Relations
  student Student @relation(fields: [studentId], references: [id])
  teacher User    @relation("TeacherAttendances", fields: [teacherId], references: [id])

  @@unique([studentId, date])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])
}

model ClassroomTeacher {
  id        String @id @default(cuid())
  userId    String
  className String

  // Relations
  user    User      @relation(fields: [userId], references: [id])
  student Student[]

  @@unique([userId, className])
}
